# Build context exclusions for the api/worker Dockerfiles.
# Both images build from the repo root so the daemon doesn't need
# anything outside the workspace tree.

# VCS
.git/
.gitignore
.gitattributes

# Agent / sync state
.claude/
.relay/
.engineering-team/
.stfolder/
.playwright-mcp/

# Per-language caches that bloat context but are never used by uv sync
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyright/
htmlcov/
.coverage
.coverage.*
.venv/
node_modules/
dist/
.vite/

# Infra / docs / journal — not consumed by the runtime images.
# alembic.ini is intentionally NOT excluded: the API Dockerfile copies
# it into the runtime image so the migration ACA Job (which reuses the
# API image) has the config alongside packages/horizons-core/migrations.
# `/scripts/` (workspace root only) is excluded — leading slash anchors
# the pattern so `packages/horizons-api/scripts/` is NOT excluded. The
# API runtime image copies `create_demo_accounts.py` for the demo-seed
# ACA Job.
infra/
docs/
journal/
/scripts/
tests/
data/
README.md
CLAUDE.md
.github/
.pre-commit-config.yaml

# Re-include the substrate the worker Dockerfile bakes in for the
# operator-driven reseed path (scripts/reseed_corpus.py +
# scripts/seed_curated_set.py + the curated set + the v1/v2 markdown).
# Negations must follow the broad exclusions above. ~1 MB of payload;
# the API image still skips these because its Dockerfile doesn't COPY
# them.
!/scripts/seed_curated_set.py
!/scripts/reseed_corpus.py
!data
!data/curated_set.yaml
!data/samples
!data/samples/**

# The webapp is its own deploy unit, not bundled into the Python images
packages/horizons-webapp/

# Editor / OS
.vscode/
.idea/
.DS_Store
*.swp
