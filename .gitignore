# Browser-automation captures — may contain JWTs or other secrets
.playwright-mcp/

# Transient agent / sync state — not source of truth
.relay/
.stfolder/
.engineering-team/
.claude/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.env
.env.*
!.env.example

# uv
.uv-cache/

# Test / coverage artefacts
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# Node / webapp build
node_modules/
dist/
.vite/
*.tsbuildinfo

# IDE / OS
.vscode/
.idea/
.DS_Store
*.swp

# Bicep — `az bicep build` output is a transient artefact; the .bicep
# sources are the truth. The .example.json parameters file is hand-written
# and IS tracked, so exclude only the compiled ARM JSON next to .bicep
# sources.
infra/main.json
infra/modules/*.json
