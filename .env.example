# Copy to .env and fill in. .env is gitignored.

# Lawstronaut API credentials — used by scripts/fetch_fixtures.py to log in
# against https://filerskeepersapi.co/auth/login and obtain a bearer token.
LAWSTRONAUT_EMAIL=
LAWSTRONAUT_PASSWORD=

# Optional URL overrides. Both default to the values shown below if unset.
# - AUTH_URL: where the login POST goes; returns the bearer token.
# - API_URL:  base for all data endpoints (/jurisdictions, /contents, etc.).
LAWSTRONAUT_AUTH_URL=https://filerskeepersapi.co/auth/login
LAWSTRONAUT_API_URL=https://api.lawstronaut.com/v2
